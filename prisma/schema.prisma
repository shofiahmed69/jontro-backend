generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  CLOSED_WON
  CLOSED_LOST
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

enum ApplicationStatus {
  RECEIVED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
}

enum ReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum WorkReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  NEEDS_REVISION
}

enum BlockerSeverity {
  NONE
  LOW
  MEDIUM
  CRITICAL
}

// ── Models ─────────────────────────────────────────────────────────

model Lead {
  id          String     @id @default(uuid())
  name        String
  email       String
  company     String?
  country     String?
  service     String?
  budget      String?
  description String
  referral    String?
  status      LeadStatus @default(NEW)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AdminUser {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String       // bcrypt hashed — never store plain text
  name           String?
  role           AdminRole    @default(EDITOR)
  createdAt      DateTime     @default(now())
  reportsAuthored WorkReport[] @relation("ReportAuthor")
  reportsReviewed WorkReport[] @relation("ReportReviewer")
}

model BlogPost {
  id             String     @id @default(uuid())
  title          String
  slug           String     @unique
  excerpt        String
  content        String     @db.Text
  heroImage      String?
  category       String
  tags           String[]
  author         TeamMember @relation(fields: [authorId], references: [id])
  authorId       String
  readTime       Int        // minutes
  published      Boolean    @default(false)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Project {
  id            String       @id @default(uuid())
  title         String
  slug          String       @unique
  client        String
  thumbnail     String?
  liveUrl       String?
  githubUrl     String?
  category      String[]
  description   String       @default("") @db.Text
  challenge     String       @db.Text
  approach      String       @db.Text
  features      String[]
  techStack     String[]
  results       String?      @db.Text
  testimonial   Testimonial? @relation(fields: [testimonialId], references: [id])
  testimonialId String?
  featured      Boolean      @default(false)
  order         Int          @default(0)
  published     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Service {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  icon           String?
  description    String   @db.Text
  features       String[]
  industries     String[]
  deliverables   String[]
  process        Json?    // Array of { step, title, description }
  useCases       String[]
  techStack      String[]
  pricingTiers   Json?    // Array of { name, price, features[] }
  faq            Json?    // Array of { question, answer }
  seoTitle       String?
  seoDescription String?
  order          Int      @default(0)
  published      Boolean  @default(true)
}

model Testimonial {
  id        String    @id @default(uuid())
  name      String
  role      String
  avatar    String?
  quote     String    @db.Text
  rating    Int?
  projects  Project[]
  published Boolean   @default(true)
  order     Int       @default(0)
}

model TeamMember {
  id          String       @id @default(uuid())
  name        String
  role        String
  department  String       @default("Operations")
  teamId      String?
  bio         String       @db.Text
  avatar      String?
  linkedIn    String?
  twitter     String?
  workEmail   String?      @unique
  passwordHash String?
  employeeActive Boolean   @default(true)
  blogPosts   BlogPost[]
  workReports WorkReport[]
  submittedReports WorkReport[] @relation("ReportSubmitter")
  order       Int          @default(0)
  published   Boolean      @default(true)
}

model JobListing {
  id               String            @id @default(uuid())
  title            String
  department       String
  type             String            // Full-time, Part-time, Contract
  location         String
  description      String            @db.Text
  responsibilities String[]
  requirements     String[]
  niceToHave       String[]
  salaryMin        Int?
  salaryMax        Int?
  published        Boolean           @default(false)
  closingDate      DateTime?
  applications     JobApplication[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model JobApplication {
  id           String            @id @default(uuid())
  job          JobListing?       @relation(fields: [jobId], references: [id])
  jobId        String?           // null = open application
  name         String
  email        String
  phone        String?
  coverLetter  String?           @db.Text
  resumeUrl    String            // Supabase Storage or Cloudinary URL
  portfolioUrl String?
  linkedIn     String?
  status       ApplicationStatus @default(RECEIVED)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Stat {
  id    String @id @default(uuid())
  label String // "Projects Delivered"
  value String // "50+"
  order Int    @default(0)
}

model WorkReport {
  id              String           @id @default(uuid())
  title           String
  periodType      ReportPeriod
  status          WorkReportStatus @default(DRAFT)
  department      String
  teamId          String?
  accomplishments String           @db.Text
  nextSteps       String           @db.Text
  blockers        String?          @db.Text
  blockerSeverity BlockerSeverity  @default(NONE)
  feedback        String?          @db.Text
  revisionCount   Int              @default(0)
  teamMember      TeamMember?      @relation(fields: [teamMemberId], references: [id])
  teamMemberId    String?
  author          AdminUser?       @relation("ReportAuthor", fields: [authorId], references: [id])
  authorId        String?
  submittedBy     TeamMember?      @relation("ReportSubmitter", fields: [submittedById], references: [id])
  submittedById   String?
  reviewer        AdminUser?       @relation("ReportReviewer", fields: [reviewedById], references: [id])
  reviewedById    String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AdminSetting {
  id                 String   @id @default("global")
  dailyCutoffTime    String   @default("18:00")
  weeklySummaryDay   String   @default("Friday")
  weeklySummaryTime  String   @default("17:00")
  emailNotifications Boolean  @default(true)
  alertRouting       Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}
